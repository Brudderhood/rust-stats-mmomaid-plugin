{
  "id": "rust_stats",
  "name": "Rust Stats + Raid",
  "version": "0.0.26",
  "capabilities": [
    "proxy:http",
    "discord:send_message",
    "events:message_content",
    "interaction:respond"
  ],
  "slash_commands": [
    {
      "name": "statscheck",
      "description": "Check a Rust player's stats by Steam ID, profile URL, or vanity name",
      "options": [
        {
          "name": "steamid",
          "description": "SteamID64, profile URL, or vanity name (steamcommunity.com/id/...)",
          "type": 3,
          "required": true
        }
      ]
    },
    {
      "name": "raidcheck",
      "description": "Calculate raid cost for a Rust wall or door",
      "options": [
        {
          "name": "target",
          "description": "Structure to raid",
          "type": 3,
          "required": true,
          "choices": [
            { "name": "Wooden Door",                "value": "woodendoor" },
            { "name": "Wood Double Door",           "value": "wooddoubledoor" },
            { "name": "Sheet Metal Door",           "value": "sheetdoor" },
            { "name": "Sheet Metal Double Door",    "value": "sheetmetaldoubledoor" },
            { "name": "Garage Door",                "value": "garagedoor" },
            { "name": "Armored Door",               "value": "armoreddoor" },
            { "name": "Armored Double Door",        "value": "armoreddoubledoor" },
            { "name": "Ladder Hatch",               "value": "ladderhatch" },
            { "name": "Wooden Wall",                "value": "woodenwall" },
            { "name": "Stone Wall (hard side)",     "value": "stonewall" },
            { "name": "Stone Wall (soft side)",     "value": "stonewallsoft" },
            { "name": "Sheet Metal Wall",           "value": "metalwall" },
            { "name": "Armored Wall (HQM)",         "value": "hqmwall" },
            { "name": "High External Wooden Wall",  "value": "highexternalwoodwall" },
            { "name": "High External Stone Wall",   "value": "highexternalstonewall" },
            { "name": "Tool Cupboard",              "value": "toolcupboard" },
            { "name": "Auto Turret",                "value": "autoturret" },
            { "name": "SAM Site",                   "value": "samsite" },
            { "name": "Vending Machine",            "value": "vendingmachine" }
          ]
        }
      ]
    }
  ]
}
